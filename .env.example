# =============================================================================
# HAXEUS — Environment Variables Template
# =============================================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets to git.
# All keys listed here are required unless marked [optional].
#
# Public variables (NEXT_PUBLIC_*) are bundled into the client-side JS bundle.
# Do NOT put secrets in NEXT_PUBLIC_* variables.
# =============================================================================


# ---------------------------------------------------------------------------
# SUPABASE — required for all database, auth, and storage operations
# ---------------------------------------------------------------------------
# Your project's Supabase URL (Dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous / publishable key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — SECRET, server-side only, NEVER expose to browser
# Used in lib/supabase-admin.ts for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# ---------------------------------------------------------------------------
# APPLICATION URLs
# ---------------------------------------------------------------------------
# Canonical public URL of the app (used in sitemap, OG tags, emails, etc.)
NEXT_PUBLIC_SITE_URL=https://haxeus.in

# Alias for NEXT_PUBLIC_SITE_URL used in some lib/ files
NEXT_PUBLIC_APP_URL=https://haxeus.in

# Public WhatsApp support number in international format, digits only
NEXT_PUBLIC_WHATSAPP_NUMBER=+91 9746283912


# ---------------------------------------------------------------------------
# PAYMENTS — Razorpay
# ---------------------------------------------------------------------------
# Publishable key — safe to expose in browser (checkout form)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_public_key_id

# Server-side key ID (same value, used for server-side order creation)
RAZORPAY_KEY_ID=rzp_live_your_key_id

# SECRET — server-side only
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Webhook signature secret — server-side only
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret


# ---------------------------------------------------------------------------
# EMAIL — Resend
# ---------------------------------------------------------------------------
# Resend API key — server-side only
RESEND_API_KEY=re_your_resend_api_key

# From address used for transactional order emails
FROM_EMAIL=orders@haxeus.in

# From address used for newsletter / marketing emails
UPDATES_EMAIL=updates@haxeus.in

# Reply-to address shown to customers
SUPPORT_EMAIL=support@haxeus.in

# [optional] Alternative Resend "from" used in some email helpers
RESEND_FROM_EMAIL=orders@haxeus.in


# ---------------------------------------------------------------------------
# CACHING — Redis (Upstash recommended for Vercel)
# ---------------------------------------------------------------------------
# [optional] Redis connection URL — falls back to no-cache if absent
REDIS_URL=redis://localhost:6379


# ---------------------------------------------------------------------------
# CRON & ADMIN SECURITY
# ---------------------------------------------------------------------------
# Secret token checked by /api/cron/* routes to prevent unauthorized calls
CRON_SECRET=replace-with-a-64-char-random-string

# Secret token checked by admin cache-bust endpoints
ADMIN_CACHE_SECRET=replace-with-a-different-64-char-random-string


# ---------------------------------------------------------------------------
# SEO & ANALYTICS
# ---------------------------------------------------------------------------
# Google Analytics 4 measurement ID [optional]
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Google Search Console site verification token [optional]
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-token

# IndexNow API key for instant search engine notification [optional]
INDEXNOW_KEY=your-indexnow-key


# ---------------------------------------------------------------------------
# WEB PUSH NOTIFICATIONS (PWA) [optional]
# ---------------------------------------------------------------------------
# VAPID public key — safe for browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID private key — server-side only, SECRET
VAPID_PRIVATE_KEY=your-vapid-private-key


# ---------------------------------------------------------------------------
# ADMIN (Development / Testing only — do NOT use in production)
# ---------------------------------------------------------------------------
# These are used by Playwright E2E tests to log in as admin.
# Set real values only in .env.local; NEVER commit real credentials.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
