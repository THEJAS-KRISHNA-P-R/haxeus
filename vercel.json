{
    "version": 2,
    "crons": [
        {
            "path": "/api/cron/abandoned-carts",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/process-emails",
            "schedule": "*/10 * * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/cron/:path*",
            "destination": "/api/cron/:path*"
        }
    ]
}